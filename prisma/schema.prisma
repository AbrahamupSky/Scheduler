generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum EventType {
  MEETING
  TIME_OFF
  TRAINING
  SPECIAL_ASSIGNMENT
  HOLIDAY
  COMPANY_EVENT
  OTHER
}

enum OptimizationPriority {
  BALANCED_WORKLOAD
  MINIMIZE_CONFLICTS
  MAXIMIZE_COVERAGE
}

enum CapabilityCode {
  FOH
  BOH
  TRUCK
  PREP
}

model Role {
  id        Int      @id @default(autoincrement())
  teamId    Int
  name      String   // ex: "FOH BOH Truck Prep" or "BOH Only"
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  caps      RoleCapability[]

  @@unique([teamId, name])
  @@index([teamId])
}

model RoleCapability {
  roleId    Int
  code      CapabilityCode
  createdAt DateTime @default(now())

  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, code])
  @@index([code])
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  sessions     Session[]
  // User owns many Teams
  teams        Team[]    @relation("OwnerTeams")
  createdAt    DateTime  @default(now())
}

model Team {
  id             Int               @id @default(autoincrement())
  name           String
  // Opposite side of User.teams
  owner          User              @relation("OwnerTeams", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId        Int

  // Opposite sides for the relations below:
  members        TeamMember[]
  roles          Role[]
  shiftTemplates ShiftTemplate[]
  irregularEvents IrregularEvent[]
  schedules      SavedSchedule[]
  rules          SchedulingRules?   // 1:1 (enforced by unique teamId in SchedulingRules)

  createdAt      DateTime          @default(now())
  @@unique([ownerId, name]) // prevent duplicate team names per owner
}

model TeamMember {
  id          Int                 @id @default(autoincrement())
  team        Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      Int
  name        String
  job         String?
  position    String?
  // Opposite side of AvailabilityWindow.member
  availability AvailabilityWindow[]

  ranking        Int?
  leadership     String?  // or Boolean? (depends on your CSV)
  minHoursWeek   Int?
  maxHoursWeek   Int?
  minDaysWeek    Int?
  maxDaysWeek    Int?
  notes          String?

  roleId   Int?
  role     Role?  @relation(fields: [roleId], references: [id], onDelete: SetNull)

  createdAt   DateTime            @default(now())
  @@unique([teamId, name])  // same person name once per team
}

model AvailabilityWindow {
  id        Int         @id @default(autoincrement())
  // Opposite field defined on TeamMember.availability
  member    TeamMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  Int
  dayOfWeek Int         // 0-6 or 1-7, your choice
  startTime String      // "HH:MM"
  endTime   String      // "HH:MM"

  @@index([memberId, dayOfWeek])
}

model ShiftTemplate {
  id         Int    @id @default(autoincrement())
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId     Int
  shift      String
  jobType    CapabilityCode  // ✅ change from String to enum
  day        String
  startTime  String
  endTime    String
  required   Int

  @@index([teamId, day, jobType, startTime, endTime])
}

model IrregularEvent {
  id        Int    @id @default(autoincrement())
  // Opposite field defined on Team.irregularEvents
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    Int
  title     String
  date      DateTime
  startTime String
  endTime   String
  jobType   CapabilityCode?
}

model SavedSchedule {
  id          Int      @id @default(autoincrement())
  // Opposite field defined on Team.schedules
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      Int
  name        String
  startDate   DateTime
  endDate     DateTime
  data        Json
  optimization String?
  createdAt   DateTime @default(now())
}

model SchedulingRules {
  id      Int   @id @default(autoincrement())
  team    Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId  Int   @unique

  // core constraints
  minHoursPerWeek    Int     @default(0)
  maxHoursPerWeek    Int     @default(40)
  maxDaysPerWeek     Int     @default(6)
  minRestHours       Int     @default(8)

  // shift-level constraints
  maxShiftHours      Int     @default(10)
  allowOvertime      Boolean @default(false)

  // fairness / preferences
  enforceFairness    Boolean @default(true)
  preferAvailability Boolean @default(true)

  notes              String?
  updatedAt          DateTime @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  token     String   @unique
  expiresAt DateTime
}